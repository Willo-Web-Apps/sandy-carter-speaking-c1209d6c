---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Sandy Carter — AI Keynote Speaker | Carter Keynotes", 
  description = "Book Sandy Carter, Fortune 25 executive and globally recognized AI keynote speaker on AI, innovation, and digital leadership. Direct booking, no bureau fees." 
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://carter-keynotes.bywillo.ai" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Sandy Carter",
      "jobTitle": "AI Keynote Speaker",
      "description": "Fortune 25 executive, published AI author, and globally recognized keynote speaker on artificial intelligence, digital transformation, and Women in Tech.",
      "url": "https://carter-keynotes.bywillo.ai",
      "sameAs": [
        "https://www.linkedin.com/in/sandycarter",
        "https://twitter.com/sandy_carter"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Carter Keynotes"
      }
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-950 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
